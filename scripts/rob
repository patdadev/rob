  collect_guild_option "$@"
  if ((${#REMAINING_ARGS[@]})); then
    set -- "${REMAINING_ARGS[@]}"
  else
    set --
  fi
  [[ $# -eq 0 ]] || die "usage: rob scan --guild <guild_id>"
  ops_get "/guilds/${GUILD_ID}/scan?format=text"
}

auto_apply_command() {
  collect_guild_option "$@"
  if ((${#REMAINING_ARGS[@]})); then
    set -- "${REMAINING_ARGS[@]}"
  else
    set --
  fi
  [[ $# -le 1 ]] || die "usage: rob auto-apply --guild <guild_id> [all|channels|roles|field_a,field_b]"
  local options="${1:-all}"
  ops_post_form "/guilds/${GUILD_ID}/scan/apply?format=text" "options=${options}"
}

