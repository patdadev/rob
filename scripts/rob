#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source_path="${BASH_SOURCE[0]}"
  while [[ -L "${source_path}" ]]; do
    local source_dir
    source_dir="$(cd -P "$(dirname "${source_path}")" && pwd)"
    source_path="$(readlink "${source_path}")"
    [[ "${source_path}" != /* ]] && source_path="${source_dir}/${source_path}"
  done
  printf '%s\n' "${source_path}"
}

SCRIPT_PATH="$(resolve_script_path)"
SCRIPT_DIR="$(cd -P "$(dirname "${SCRIPT_PATH}")" && pwd)"
APP_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

ROB_BOT_SERVICE="${ROB_BOT_SERVICE:-rob-bot-dev.service}"
ROB_WEBHOOK_SERVICE="${ROB_WEBHOOK_SERVICE:-rob-webhook-dev.service}"
PYTHON_BIN="${PYTHON_BIN:-python3}"

if [[ -f "${APP_ROOT}/.env" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "${APP_ROOT}/.env"
  set +a
fi

export PYTHONPATH="${PYTHONPATH:-${APP_ROOT}}"

if [[ ":${PYTHONPATH}:" != *":${APP_ROOT}:"* ]]; then
  export PYTHONPATH="${APP_ROOT}:${PYTHONPATH}"
fi

usage() {
  cat <<'EOF'
Rob Control
========================================================================
Most used:
  rob status                     # db + queue + maintenance + service state
  rob leaderboard refresh        # refresh leaderboard messages
  rob guild scan --guild-id ID   # scan channels/roles + suggest fixes
  rob sends list --guild-id ID
  rob maintenance on|off

Short aliases:
  rob lb ...   -> rob leaderboard ...
  rob q ...    -> rob queue ...
  rob m ...    -> rob maintenance ...
  rob g ...    -> rob guild ...
  rob s ...    -> rob sends ...
  rob t ...    -> rob throne ...
  rob c ...    -> rob count ...
  rob i ...    -> rob inactivity ...
  rob bl ...   -> rob blacklist ...

Compatibility:
  robctl ...  (same command surface)

Tip:
  Run `rob <command> --help` for full options.
EOF
}

run_ops() {
  "${PYTHON_BIN}" -m scripts.ops "$@"
}

service_name() {
  case "${1:-bot}" in
    bot) printf '%s\n' "${ROB_BOT_SERVICE}" ;;
    webhook) printf '%s\n' "${ROB_WEBHOOK_SERVICE}" ;;
    *) return 1 ;;
  esac
}

print_header() {
  local title="$1"
  echo "========================================================================"
  echo "Rob Control | ${title}"
  echo "========================================================================"
}

print_field() {
  local label="$1"
  local value="$2"
  echo "- ${label}: ${value}"
}

cmd="${1:-}"
if [[ -z "${cmd}" || "${cmd}" == "help" || "${cmd}" == "--help" || "${cmd}" == "-h" ]]; then
  usage
  exit 0
fi
shift || true

case "${cmd}" in
  lb|leaderboards) cmd="leaderboard" ;;
  q) cmd="queue" ;;
  m) cmd="maintenance" ;;
  g) cmd="guild" ;;
  s|send) cmd="sends" ;;
  t) cmd="throne" ;;
  c) cmd="count" ;;
  i|inactive) cmd="inactivity" ;;
  bl) cmd="blacklist" ;;
  l) cmd="logs" ;;
  r) cmd="restart" ;;
esac

case "${cmd}" in
  status)
    run_ops status
    if command -v systemctl >/dev/null 2>&1; then
      bot_service="$(systemctl is-active "${ROB_BOT_SERVICE}" 2>/dev/null || true)"
      webhook_service="$(systemctl is-active "${ROB_WEBHOOK_SERVICE}" 2>/dev/null || true)"
      print_header "Services"
      print_field "Bot Service" "${bot_service}"
      print_field "Webhook Service" "${webhook_service}"
    fi
    ;;
  logs)
    target="${1:-bot}"
    service="$(service_name "${target}")"
    exec journalctl -u "${service}" -n 100 -f
    ;;
  restart)
    target="${1:-all}"
    if ! command -v systemctl >/dev/null 2>&1; then
      echo "systemctl is not available on this machine." >&2
      exit 1
    fi
    case "${target}" in
      bot|webhook)
        sudo systemctl restart "$(service_name "${target}")"
        print_header "Restart"
        print_field "Target" "${target}"
        print_field "Result" "restarted"
        ;;
      all)
        sudo systemctl restart "${ROB_WEBHOOK_SERVICE}"
        sudo systemctl restart "${ROB_BOT_SERVICE}"
        print_header "Restart"
        print_field "Target" "all"
        print_field "Result" "restarted"
        ;;
      *)
        echo "Unknown restart target: ${target}" >&2
        exit 1
        ;;
    esac
    ;;
  maintenance|queue|leaderboard|count|throne|sends|inactivity|blacklist|guild)
    run_ops "${cmd}" "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
