webhook_command() {
  local action="${1:-}"
  shift || true

  case "${action}" in
    preview)
      collect_guild_option "$@"
      if ((${#REMAINING_ARGS[@]})); then
        set -- "${REMAINING_ARGS[@]}"
      else
        set --
      fi
      [[ $# -eq 0 ]] || die "usage: rob webhook preview --guild <guild_id>"
      ops_get "/guilds/${GUILD_ID}/webhook/reissue/preview?format=text"
      ;;
    send)
      collect_guild_option "$@"
      if ((${#REMAINING_ARGS[@]})); then
        set -- "${REMAINING_ARGS[@]}"
      else
        set --
      fi
      local send_all="false"
      local target_user_id=""
      local limit=""
      while (($#)); do
        case "$1" in
          --all)
            send_all="true"
            ;;
          --discord-user-id)
            shift
            (($#)) || die "missing value for --discord-user-id"
            target_user_id="$1"
            ;;
          --discord-user-id=*)
            target_user_id="${1#*=}"
            ;;
          --limit)
            shift
            (($#)) || die "missing value for --limit"
            limit="$1"
            ;;
          --limit=*)
            limit="${1#*=}"
            ;;
          *)
            die "usage: rob webhook send --guild <guild_id> --all [--limit <n>] | --discord-user-id <id>"
            ;;
        esac
        shift || true
      done
      if [[ "${send_all}" != "true" && -z "${target_user_id}" ]]; then
        die "usage: rob webhook send --guild <guild_id> --all [--limit <n>] | --discord-user-id <id>"
      fi
      if [[ -n "${target_user_id}" && ! "${target_user_id}" =~ ^[0-9]+$ ]]; then
        die "discord user id must be numeric."
      fi
      if [[ -n "${limit}" && ! "${limit}" =~ ^[0-9]+$ ]]; then
        die "limit must be numeric."
      fi
      local -a form_args
      form_args=()
      if [[ "${send_all}" == "true" ]]; then
        form_args+=("all=true")
      fi
      if [[ -n "${target_user_id}" ]]; then
        form_args+=("discord_user_id=${target_user_id}")
      fi
      if [[ -n "${limit}" ]]; then
        form_args+=("limit=${limit}")
      fi
      ops_post_form "/guilds/${GUILD_ID}/webhook/reissue/send?format=text" "${form_args[@]}"
      ;;
    refresh)
      collect_guild_option "$@"
      if ((${#REMAINING_ARGS[@]})); then
        set -- "${REMAINING_ARGS[@]}"
      else
        set --
      fi
      [[ $# -eq 1 ]] || die "usage: rob webhook refresh <thronehandle> [--guild <guild_id>]"
      ops_post_form "/guilds/${GUILD_ID}/webhook/reissue/refresh?format=text" "domme_lookup=$1"
      ;;
    *)
      die "usage: rob webhook preview|send|refresh ..."
      ;;
  esac
}

clear_command() {
  [[ $# -eq 1 ]] || die "usage: rob clear rob_dev_v2"
  [[ "$1" == "rob_dev_v2" ]] || die "usage: rob clear rob_dev_v2"
  require_database_url

  local current_db
  current_db="$(database_name_from_url)"
  local tables=(
    send_change_requests
    achievement_events
    user_achievements
    count_blocks
    count_recovery_windows
    sub_send_names
    inactive_users
    vib_leaderboard
    sends
    subs
    dommes
    bot_users
    the_count
    vib_settings
    bot_settings
  )

  print_heading "Rehearsal DB Clear Preview"
  printf 'Target Database: %s\n' "${current_db}"
  printf 'Mode: SQL preview only (nothing will be executed)\n'
  printf 'Schema: preserved\n'
  printf 'Indexes: preserved\n'
  printf 'db_build_version: preserved\n'
  printf 'Intended Database: rob_dev_v2\n'
  if [[ "${current_db}" != "rob_dev_v2" ]]; then
    printf 'WARNING: DATABASE_URL currently points at %s, not rob_dev_v2.\n' "${current_db}"
  fi
  printf '\nRows that would be cleared\n'
  printf '%s\n' '========================='
  local table
  for table in "${tables[@]}"; do
    local count
    count="$(psql_query "SELECT COUNT(*) FROM ${table}")"
    printf -- '- %s: %s\n' "${table}" "${count:-0}"
  done
  printf '\nSQL to run manually as doadmin\n'
  printf '%s\n' '============================='
  cat <<'EOF'
-- Rehearsal DB only.
-- Preserves schema, indexes, and db_build_version.
-- Review before running. Do not use this on prod.
TRUNCATE TABLE
    send_change_requests,
    achievement_events,
    user_achievements,
    count_blocks,
    count_recovery_windows,
    sub_send_names,
    inactive_users,
    vib_leaderboard,
    sends,
    subs,
    dommes,
    bot_users,
    the_count,
    vib_settings,
    bot_settings
RESTART IDENTITY CASCADE;
EOF
}

maintenance_command() {
  local action="${1:-status}"
  shift || true

  case "${action}" in
    status)
      ops_get "/maintenance?format=text"
      ;;
    on)
      local reason="Enabled via rob CLI"
      if (($#)); then
        reason="$*"
      fi
      ops_post_form "/maintenance?format=text" "enabled=true" "reason=${reason}"
      ;;
    off)
      ops_post_form "/maintenance?format=text" "enabled=false"
      ;;
    *)
      die "usage: rob maintenance on|off|status"
      ;;
  esac
}

block_command() {
  [[ $# -eq 1 ]] || die "usage: rob block <discord_user_id>"
  [[ "$1" =~ ^[0-9]+$ ]] || die "discord_user_id must be numeric."
  ops_post_form "/block?format=text" "discord_user_id=$1" "reason=blocked via rob CLI"
}

unblock_command() {
  [[ $# -eq 1 ]] || die "usage: rob unblock <discord_user_id>"
  [[ "$1" =~ ^[0-9]+$ ]] || die "discord_user_id must be numeric."
  ops_post_form "/unblock?format=text" "discord_user_id=$1"
}

restart_command() {
  command -v systemctl >/dev/null 2>&1 || die "systemctl is not available on this machine."
  services_for_target "${1:-all}"
  require_cmd sudo
  sudo systemctl restart "${SERVICE_TARGETS[@]}"
  sudo systemctl is-active "${SERVICE_TARGETS[@]}"
}

logs_command() {
  command -v journalctl >/dev/null 2>&1 || die "journalctl is not available on this machine."
  services_for_target "${1:-all}"
  local -a args
  args=()
  for service_name in "${SERVICE_TARGETS[@]}"; do
    args+=(-u "${service_name}")
  done
  exec journalctl "${args[@]}" -n "${ROB_LOG_LINES}" -f
}

cmd="${1:-}"
[[ -n "${cmd}" ]] || {
  usage
  exit 0
}
shift || true

case "${cmd}" in
  help|--help|-h)
    usage
    ;;
  dommes)
    dommes_command "$@"
    ;;
  subs)
    subs_command "$@"
    ;;
  sends)
    sends_lookup_command "$@"
    ;;
  send)
    send_command "$@"
    ;;
  count)
    count_command "$@"
    ;;
  scan)
    scan_command "$@"
    ;;
  auto-apply)
    auto_apply_command "$@"
    ;;
  achievement|achievements)
    achievement_command "$@"
    ;;
  migration)
    migration_command "$@"
    ;;
  webhook)
    webhook_command "$@"
    ;;
  clear)
    clear_command "$@"
    ;;
  block)
    block_command "$@"
    ;;
  unblock)
    unblock_command "$@"
    ;;
  restart)
    restart_command "$@"
    ;;
  maintenance)
    maintenance_command "$@"
    ;;
  logs)
    logs_command "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
