APP_ENV=dev
LOG_LEVEL=INFO

# Runtime DB URL for the current service process (bot OR webhook).
# Dev examples:
# DATABASE_URL=postgresql://rob_dev_bot:<password>@<host>:<port>/rob_dev?sslmode=require
# DATABASE_URL=postgresql://rob_dev_webhook:<password>@<host>:<port>/rob_dev?sslmode=require
#
# Prod examples:
# DATABASE_URL=postgresql://rob_prod_bot:<password>@<host>:<port>/rob_prod?sslmode=require
# DATABASE_URL=postgresql://rob_prod_webhook:<password>@<host>:<port>/rob_prod?sslmode=require
DATABASE_URL=postgresql://rob_dev_bot:replace@127.0.0.1:5432/rob_dev?sslmode=require

# Used by scripts/run_migrations.py (preferred) to keep schema-owner credentials
# out of runtime services.
# Dev:
# MIGRATION_DATABASE_URL=postgresql://rob_dev_migrator:<password>@<host>:<port>/rob_dev?sslmode=require
# Prod:
# MIGRATION_DATABASE_URL=postgresql://rob_prod_migrator:<password>@<host>:<port>/rob_prod?sslmode=require
MIGRATION_DATABASE_URL=

# Portal service only
ROB_PORTAL_ENABLED=false
ROB_PORTAL_ENV=dev
ROB_PORTAL_BASE_URL=https://rob-dev.barecoding.com
ROB_PORTAL_SECRET_KEY=
ROB_PORTAL_ALLOWED_HOSTS=rob-dev.barecoding.com,127.0.0.1,localhost
ROB_PORTAL_CSRF_TRUSTED_ORIGINS=https://rob-dev.barecoding.com
ROB_PORTAL_SUPERADMIN_USER_IDS=1299308718009356289

# Portal Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://rob-dev.barecoding.com/portal/auth/discord/callback

# Portal DB URL (preferred over DATABASE_URL when running portal)
PORTAL_DATABASE_URL=postgresql://rob_dev_portal:replace@127.0.0.1:5432/rob_dev?sslmode=require
PORTAL_MIGRATION_DATABASE_URL=

# Bot ops bridge (keep private/internal)
ROB_OPS_HOST=127.0.0.1
ROB_OPS_PORT=8811
ROB_OPS_SECRET=
ROB_PORTAL_ALLOWED_SERVICES=rob-bot-dev.service,rob-webhook-dev.service,rob-portal-dev.service
ROB_PORTAL_ENABLE_SERVICE_ACTIONS=false

# Split-server portal + bot example:
# ROB_OPS_HOST=<bot-server-private-ip-or-dns>
# ROB_OPS_PORT=8811
# ROB_OPS_SECRET=<same-secret-as-bot>
# Security: do NOT expose bot ops bridge publicly. Use private networking
# (firewall allowlist, VPN, private tunnel, or internal routing only).

# Bot server only
DISCORD_TOKEN=replace
BOT_NAME=Rob Dev

# Webhook server only
THRONE_WEBHOOK_HOST=127.0.0.1
THRONE_WEBHOOK_PORT=8080
THRONE_WEBHOOK_BASE_URL=https://rob-dev.barecoding.com
# Set to false for early/local dev when you do not yet have a verified
# Throne public key and signed-message format. Leave true once signature
# validation is confirmed for the dev tunnel.
THRONE_WEBHOOK_REQUIRE_SIGNATURE=true
THRONE_PUBLIC_KEY_PEM=
THRONE_WEBHOOK_DEBUG_LOG_PAYLOAD=false

THRONE_WEBHOOK_TIMESTAMP_HEADER=X-Signature-Timestamp
THRONE_WEBHOOK_SIGNATURE_HEADER=X-Signature-Ed25519
THRONE_WEBHOOK_SIGNED_MESSAGE_FORMAT=timestamp_dot_body
THRONE_WEBHOOK_MAX_TIMESTAMP_SKEW_SECONDS=300

THRONE_PARSE_TEST_SENDS_AS_REAL_SENDS=false
THRONE_TEST_GIFTER_USERNAMES=marie_123
THRONE_TEST_SEND_LEADERBOARD_OWNER_USER_ID=
LEADERBOARD_LIMIT=10
SEND_QUEUE_LOOP_SECONDS=10

# Inactivity system
INACTIVITY_ENABLED_DEFAULT=false
INACTIVITY_LOOP_MINUTES=60
INACTIVITY_NEW_MEMBER_GRACE_DAYS=7
INACTIVITY_ASSIGNMENT_GRACE_DAYS=14
INACTIVITY_BOOTSTRAP_GRACE_DAYS=21
INACTIVITY_FINAL_NOTICE_DAYS=7
INACTIVITY_OWNER_USER_ID=
INACTIVITY_NOTICE_CHANNEL_ID=
