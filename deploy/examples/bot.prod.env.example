APP_ENV=prod
LOG_LEVEL=INFO

# Bot runtime DB user against the production database.
DATABASE_URL=postgresql://prod_rob_bot:<password>@<db-host>:25060/rob_prod?sslmode=require

# Bot server only.
DISCORD_TOKEN=<discord-bot-token>
DISCORD_GUILD_ID=1506597978251591813
BOT_NAME=Rob

# Bind to the bot server's private IP so the webhook host can notify it.
ROB_OPS_HOST=10.100.0.2
ROB_OPS_PORT=8811
ROB_OPS_SECRET=<shared-long-random-secret>

# Used when Rob shows Dom/me webhook setup URLs.
THRONE_WEBHOOK_BASE_URL=https://throne.robthebot.com

THRONE_PARSE_TEST_SENDS_AS_REAL_SENDS=false
THRONE_TEST_GIFTER_USERNAMES=marie_123
THRONE_TEST_SEND_LEADERBOARD_OWNER_USER_ID=

ROB_PUBLIC_BASE_URL=https://leaderboard.robthebot.com
LEADERBOARD_LIMIT=10
SEND_QUEUE_LOOP_SECONDS=60
PUBLIC_LEADERBOARD_CACHE_SECONDS=60

INACTIVITY_ENABLED_DEFAULT=false
INACTIVITY_LOOP_MINUTES=60
INACTIVITY_NEW_MEMBER_GRACE_DAYS=7
INACTIVITY_ASSIGNMENT_GRACE_DAYS=14
INACTIVITY_BOOTSTRAP_GRACE_DAYS=21
INACTIVITY_FINAL_NOTICE_DAYS=7
INACTIVITY_OWNER_USER_ID=
INACTIVITY_NOTICE_CHANNEL_ID=

ACHIEVEMENTS_ENABLED=false
